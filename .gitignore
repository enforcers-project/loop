# Root-level ignores shared across backend/ and frontend/.
# Each folder also has its own .gitignore for build output.

# Dependencies
node_modules/

# Environment — never commit real secrets; only *.env.example is tracked.
.env
.env.*
!.env.example

# Build output
dist/
dist-ssr/
build/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor / OS
.DS_Store
.idea/
*.local

# Keep .vscode out except shared settings, if any are added later
.vscode/*
!.vscode/extensions.json
