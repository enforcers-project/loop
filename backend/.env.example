# Loop backend — copy to .env and fill in from the shared password manager ("Loop").
PORT=3000

# Event APIs (backend-only — never expose these to the frontend):
TICKETMASTER_API_KEY=
SEATGEEK_CLIENT_ID=
SEATGEEK_CLIENT_SECRET=
# Only if geocoding/places move server-side (map runs in the browser for now):
# GOOGLE_MAPS_API_KEY=

# Database (required — Postgres + pgvector via docker-compose.yml):
DATABASE_URL=postgresql://loop:loop@localhost:5433/loop

# Auth (required) — secret for signing the stateless JWT auth cookie. Any long
# random string for local dev; production uses a real secret from the deploy env.
JWT_SECRET=change-me

# Google Sign-In (optional) — OAuth 2.0 Web client ID from Google Cloud Console.
# Backend verifies the browser's id_token against this audience. When unset, the
# POST /api/auth/oauth/google endpoint returns 503 NOT_CONFIGURED (email/password
# auth is unaffected). Client ids are not secret, but keep it in env for parity.
# GOOGLE_CLIENT_ID=

# Backend-only AI keys (never expose to the frontend):
# LLM — Groq (NL-search parse, auto-tagging, AI descriptions, chat assistant):
# GROQ_API_KEY=
# Embeddings — Hugging Face Inference API, all-MiniLM-L6-v2 → vector(384):
# HF_API_TOKEN=
# (If MiniLM is later self-hosted on Fly/Railway instead of HF, swap HF_API_TOKEN
#  for the internal embed-service URL — e.g. EMBEDDINGS_URL=http://embed:8000/embed)
