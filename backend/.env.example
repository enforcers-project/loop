# Loop backend — copy to .env and fill in from the shared password manager ("Loop").
PORT=3000

# Event APIs (backend-only — never expose these to the frontend):
TICKETMASTER_API_KEY=
SEATGEEK_CLIENT_ID=
SEATGEEK_CLIENT_SECRET=
# Only if geocoding/places move server-side (map runs in the browser for now):
# GOOGLE_MAPS_API_KEY=

# Database (required — Postgres + pgvector via docker-compose.yml):
DATABASE_URL=postgresql://loop:loop@localhost:5433/loop

# Auth (required) — secret for signing the stateless JWT auth cookie. Any long
# random string for local dev; production uses a real secret from the deploy env.
JWT_SECRET=change-me

# Google Sign-In (optional) — OAuth 2.0 Web client ID from Google Cloud Console.
# Backend verifies the browser's id_token against this audience. When unset, the
# POST /api/auth/oauth/google endpoint returns 503 NOT_CONFIGURED (email/password
# auth is unaffected). Client ids are not secret, but keep it in env for parity.
# GOOGLE_CLIENT_ID=

# Profile pictures — Amazon S3 (public-read bucket, presigned-URL uploads).
# When AWS_REGION + S3_AVATAR_BUCKET are set, POST /api/users/:id/avatar-upload-url
# mints a presigned PUT so the browser uploads straight to S3. Credentials are an
# IAM user with s3:PutObject on the bucket. DEFAULT_AVATAR_URL is the public URL
# of the silhouette every new user starts with (upload it once to the bucket).
# When unset, uploads return 503 and new users get a null avatar (client default).
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_AVATAR_BUCKET=loop-avatars-prod
# DEFAULT_AVATAR_URL=https://loop-avatars-prod.s3.us-east-1.amazonaws.com/defaults/avatar.png

# Backend-only AI keys (never expose to the frontend):
# LLM — Groq (NL-search parse #22, auto-tag #24, AI description #25, chat).
# Model: llama-3.1-8b-instant (parse/tag) + llama-3.3-70b-versatile (chat/desc).
# Get a key at console.groq.com/keys (free tier is enough for dev).
GROQ_API_KEY=
# Embeddings — Cloudflare Workers AI, bge-small-en-v1.5 → vector(384).
# (Plan originally specced Hugging Face all-MiniLM; implemented on Cloudflare.
#  Same 384 dims, so vector columns are unchanged. See src/embeddings/embed.js.)
# CF_ACCOUNT_ID=
# CF_API_TOKEN=
# USE_REMOTE_EMBED=1
# Image gen — OpenAI gpt-image-1 (organizer flyer generation on Create Event).
# From platform.openai.com → API keys. Starts with "sk-". Portrait 1024x1536 at
# medium quality is ~$0.063/image. When unset, POST /api/ai/flyer returns 503.
# OPENAI_API_KEY=
